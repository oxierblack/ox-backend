# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Database ────────────────────────────────────────────
# MongoDB Atlas connection string (or any reachable MongoDB instance)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/oxier?retryWrites=true&w=majority

# ── Auth ────────────────────────────────────────────────
# Use a long random string in production, e.g: openssl rand -hex 64
JWT_SECRET=change_this_to_a_long_random_secret

# ── Default admin (created automatically on first boot) ─
ADMIN_EMAIL=admin@oxier.com
ADMIN_PASSWORD=Admin@123456

# ── Email (Resend) ──────────────────────────────────────
# If unset, OTP codes are logged to the console only (dev fallback).
RESEND_API_KEY=re_SR3VNzpU_8QKwdrakAJJZkUNXNwKWcpP7

# ── Frontend ────────────────────────────────────────────
# Used to build partner invite links: {FRONTEND_URL}/join?ref=CODE
FRONTEND_URL=https://your-frontend-domain.com

# ── File uploads ────────────────────────────────────────
# Used to build public URLs for uploaded deposit proof screenshots.
# Set this to your Railway public domain, e.g. https://oxier-api.up.railway.app
BASE_URL=
